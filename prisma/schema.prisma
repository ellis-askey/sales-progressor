// Sales Progressor - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modeProfile           AgencyModeProfile @default(self_progressed)
  modeProfileComputedAt DateTime?

  // Signup attribution
  signupSource      String?
  signupMedium      String?
  signupCampaign    String?
  signupReferrer    String?
  signupLandingPage String?
  signupAt          DateTime?

  users                    User[]
  transactions             PropertyTransaction[]
  solicitorFirms           SolicitorFirm[]
  manualTasks              ManualTask[]
  chains                   PropertyChain[]
  verifiedDomains          VerifiedDomain[]
  recommendedSolicitors    AgencyRecommendedSolicitor[]
  feedbackSubmissions      FeedbackSubmission[]

  @@index([modeProfile])
  @@index([signupAt])
}

enum AgencyModeProfile {
  self_progressed
  progressor_managed
  mixed
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  password        String?
  totpSecret      String?
  totpActivatedAt DateTime?
  role            UserRole   @default(viewer)
  agencyId        String?
  firmName        String?
  progressorId    String?
  clientType      ClientType @default(standard)
  legacyFee       Int?
  phone                String?
  canViewAllFiles      Boolean    @default(false)
  hasSeenAgentWelcome  Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  agency               Agency?               @relation(fields: [agencyId], references: [id])
  progressor           User?                 @relation("ProgressorAgents", fields: [progressorId], references: [id])
  managedAgents        User[]                @relation("ProgressorAgents")
  assignedTransactions PropertyTransaction[] @relation("AssignedUser")
  agentFiles           PropertyTransaction[] @relation("AgentFiles")
  milestoneCompletions MilestoneCompletion[] @relation("CompletedBy")
  chaseTasks           ChaseTask[]
  communications       OutboundMessage[] @relation("CommCreatedBy")
  sentPortalMessages   PortalMessage[]       @relation("PortalMessagesSentBy")

  retentionEmailOptOut    Boolean   @default(false)

  emailVerified        DateTime?
  image                String?
  accounts             Account[]
  sessions             Session[]
  transactionNotes     TransactionNote[]
  createdManualTasks   ManualTask[]       @relation("ManualTaskCreator")
  assignedManualTasks  ManualTask[]       @relation("ManualTaskAssignee")
  createdDomains       VerifiedDomain[]   @relation("DomainCreatedBy")
  verifiedEmails       UserVerifiedEmail[]
  feedbackSubmissions  FeedbackSubmission[]
  agentPushSubscriptions AgentPushSubscription[]
  retentionEmailLogs   RetentionEmailLog[]
  commandPreferences   Json?
}

model AgentPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  superadmin
  admin
  sales_progressor
  director
  negotiator
  viewer
}

enum ClientType {
  legacy
  standard
}

enum ServiceType {
  self_managed
  outsourced
}

enum ProgressedBy {
  progressor
  agent
}

model PropertyTransaction {
  id                           String            @id @default(cuid())
  propertyAddress              String
  status                       TransactionStatus @default(active)
  agencyId                     String
  assignedUserId               String?
  agentUserId                  String?
  progressedBy                 ProgressedBy      @default(progressor)
  serviceType                  ServiceType       @default(self_managed)
  expectedExchangeDate         DateTime?
  purchasePrice                Int?
  tenure                       Tenure?
  purchaseType                 PurchaseType?
  twelveWeekTarget             DateTime?
  predictedExchangeDate        DateTime?
  overridePredictedDate        DateTime?
  completionDate               DateTime?
  agentFeeAmount               Int?
  agentFeePercent              Decimal?
  agentFeeIsVatInclusive       Boolean?
  notes                        String?
  fallThroughReason            String?
  referredFirmId               String?
  referralFee                  Int?
  referralFeeReceived          Boolean               @default(false)
  vendorSolicitorFirmId        String?
  vendorSolicitorContactId     String?
  purchaserSolicitorFirmId     String?
  purchaserSolicitorContactId  String?
  lastActivityAt               DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  agency                     Agency                @relation(fields: [agencyId], references: [id])
  assignedUser               User?                 @relation("AssignedUser", fields: [assignedUserId], references: [id])
  agentUser                  User?                 @relation("AgentFiles", fields: [agentUserId], references: [id])
  contacts                   Contact[]
  vendorSolicitorFirm        SolicitorFirm?        @relation("VendorSolicitorFirm",    fields: [vendorSolicitorFirmId],    references: [id])
  vendorSolicitorContact     SolicitorContact?     @relation("VendorSolicitorContact",  fields: [vendorSolicitorContactId],  references: [id])
  purchaserSolicitorFirm     SolicitorFirm?        @relation("PurchaserSolicitorFirm", fields: [purchaserSolicitorFirmId], references: [id])
  purchaserSolicitorContact  SolicitorContact?     @relation("PurchaserSolicitorContact", fields: [purchaserSolicitorContactId], references: [id])
  referredFirm               SolicitorFirm?        @relation("ReferredFirm",           fields: [referredFirmId],           references: [id])
  milestoneCompletions       MilestoneCompletion[]
  reminderLogs               ReminderLog[]
  chaseTasks                 ChaseTask[]
  communications             OutboundMessage[]
  priceHistory               PriceHistory[]
  transactionNotes           TransactionNote[]
  manualTasks                ManualTask[]
  chainLinks                 ChainLink[]
  portalMessages             PortalMessage[]
  documents                  TransactionDocument[]
  flags                      TransactionFlag[]

  @@index([serviceType, createdAt])
}

enum TransactionStatus {
  draft
  active
  on_hold
  completed
  withdrawn
}

enum Tenure {
  freehold
  leasehold
}

enum PurchaseType {
  mortgage
  cash_buyer
  cash_from_proceeds
}

enum MilestoneState {
  locked
  available
  complete
  not_required
}

enum CanBeMarkedNr {
  never
  auto_only
  manual_allowed
}

model PriceHistory {
  id            String   @id @default(cuid())
  transactionId String
  oldPrice      Int?
  newPrice      Int
  changedById   String?
  reason        String?
  createdAt     DateTime @default(now())

  transaction PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Contact {
  id                    String      @id @default(cuid())
  propertyTransactionId String
  name                  String
  phone                 String?
  email                 String?
  roleType              ContactRole
  portalToken           String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  transaction       PropertyTransaction @relation(fields: [propertyTransactionId], references: [id], onDelete: Cascade)
  pushSubscriptions PortalPushSubscription[]
  portalMessages    PortalMessage[]
  documents         TransactionDocument[]
}

model PortalPushSubscription {
  id        String   @id @default(cuid())
  contactId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model PortalMessage {
  id            String    @id @default(cuid())
  transactionId String
  contactId     String
  content       String
  fromClient    Boolean   @default(true)
  sentById      String?
  createdAt     DateTime  @default(now())

  transaction   PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  contact       Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sentBy        User?               @relation("PortalMessagesSentBy", fields: [sentById], references: [id])

  @@index([transactionId, contactId, createdAt])
}

model SolicitorFirm {
  id        String   @id @default(cuid())
  agencyId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency   Agency             @relation(fields: [agencyId], references: [id])
  handlers SolicitorContact[]
  vendorForTransactions    PropertyTransaction[] @relation("VendorSolicitorFirm")
  purchaserForTransactions PropertyTransaction[] @relation("PurchaserSolicitorFirm")
  referredForTransactions  PropertyTransaction[] @relation("ReferredFirm")
  recommendations          AgencyRecommendedSolicitor[]

  @@unique([name])
}

model AgencyRecommendedSolicitor {
  id                      String   @id @default(cuid())
  agencyId                String
  solicitorFirmId         String
  defaultReferralFeePence Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  agency        Agency        @relation(fields: [agencyId], references: [id])
  solicitorFirm SolicitorFirm @relation(fields: [solicitorFirmId], references: [id], onDelete: Cascade)

  @@unique([agencyId, solicitorFirmId])
  @@index([agencyId])
}

model SolicitorContact {
  id        String   @id @default(cuid())
  firmId    String
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm SolicitorFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  vendorForTransactions    PropertyTransaction[] @relation("VendorSolicitorContact")
  purchaserForTransactions PropertyTransaction[] @relation("PurchaserSolicitorContact")
}

enum ContactRole {
  vendor
  purchaser
  solicitor
  broker
  other
}

// ─── MilestoneDefinition ──────────────────────────────────────────────────────

model MilestoneDefinition {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  side            MilestoneSide
  orderIndex      Int
  blocksExchange     Boolean       @default(true)
  eventDateRequired  Boolean       @default(false)
  predecessorCode    String?
  canBeMarkedNr      CanBeMarkedNr @default(never)
  summaryTemplate String        @default("")
  weight          Decimal       @default(0)
  createdAt       DateTime      @default(now())

  completions   MilestoneCompletion[]
  reminderRules ReminderRule[]        @relation("AnchorMilestone")
}

enum MilestoneSide {
  vendor
  purchaser
}

model MilestoneCompletion {
  id                    String         @id @default(cuid())
  transactionId         String
  milestoneDefinitionId String
  state                 MilestoneState @default(locked)
  completedAt           DateTime?
  eventDate             DateTime?
  notRequiredReason     String?
  completedById         String?
  confirmedByPortal     Boolean        @default(false)
  summaryText           String?
  reconciledAtExchange  Boolean        @default(false)
  outOfOrderCompletion  Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  transaction         PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  milestoneDefinition MilestoneDefinition @relation(fields: [milestoneDefinitionId], references: [id])
  completedBy         User?               @relation("CompletedBy", fields: [completedById], references: [id])

  @@unique([transactionId, milestoneDefinitionId])
  @@index([transactionId, completedAt])
}

// ─── ReminderRule ─────────────────────────────────────────────────────────────

model ReminderRule {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  anchorMilestoneId     String?
  targetMilestoneCode   String?
  graceDays             Int      @default(3)
  repeatEveryDays       Int      @default(5)
  escalateAfterChases   Int      @default(3)
  requiresExchangeReady Boolean  @default(false)
  useEventDate          Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  anchorMilestone MilestoneDefinition? @relation("AnchorMilestone", fields: [anchorMilestoneId], references: [id])
  reminderLogs    ReminderLog[]
}

model ReminderLog {
  id             String            @id @default(cuid())
  transactionId  String
  reminderRuleId String
  status         ReminderLogStatus @default(active)
  nextDueDate    DateTime
  sourceDateUsed DateTime?
  statusReason   String?
  snoozedUntil   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  transaction  PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reminderRule ReminderRule        @relation(fields: [reminderRuleId], references: [id])
  chaseTasks   ChaseTask[]

  @@index([transactionId, reminderRuleId])
  @@index([status, nextDueDate])
}

enum ReminderLogStatus {
  active
  completed
  cancelled
  inactive
}

model ChaseTask {
  id            String          @id @default(cuid())
  transactionId String
  reminderLogId String
  assignedToId  String?
  dueDate       DateTime
  status        ChaseTaskStatus @default(pending)
  priority      TaskPriority    @default(normal)
  chaseCount    Int             @default(0)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  transaction    PropertyTransaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reminderLog    ReminderLog           @relation(fields: [reminderLogId], references: [id])
  assignedTo     User?                 @relation(fields: [assignedToId], references: [id])
  communications OutboundMessage[]

  @@index([transactionId])
  @@index([status, dueDate])
  @@index([priority, status])
}

enum ChaseTaskStatus {
  pending
  done
  cancelled
  inactive
}

enum TaskPriority {
  normal
  escalated
}

model OutboundMessage {
  id              String          @id @default(cuid())
  agencyId        String?

  // Channel + purpose (command centre fields)
  channel         OutboundChannel @default(email)
  purpose         OutboundPurpose @default(chase)
  status          OutboundStatus  @default(sent)

  // Routing — transactionId is nullable (non-transaction messages: LinkedIn, digest, etc.)
  transactionId   String?
  chaseTaskId     String?
  recipientName   String?
  recipientEmail  String?
  recipientHandle String?

  // Content — legacy fields kept for backward compat
  type            CommType
  method          CommMethod?
  contactIds      String[]
  content         String
  subject         String?
  bodyFormat      String          @default("plain")

  // Legacy AI fields
  generatedText   String?
  tone            String?
  wasAiGenerated  Boolean         @default(false)
  wasEdited       Boolean         @default(false)
  isAutomated     Boolean         @default(false)
  visibleToClient Boolean         @default(false)
  ccEmails        String?

  // New AI provenance
  aiModel         String?
  aiPromptVersion String?
  aiTokensInput   Int?
  aiTokensOutput  Int?
  aiCostCents     Int?

  // Lifecycle
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduledFor    DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  failedAt        DateTime?
  failureReason   String?

  // Approval (Phase 5 LinkedIn flow)
  requiresApproval  Boolean       @default(false)
  approvedByUserId  String?
  approvedAt        DateTime?
  editedByHuman     Boolean       @default(false)

  // Provider data
  providerMessageId   String?
  providerWebhookData Json?

  transaction PropertyTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdBy   User?                @relation("CommCreatedBy", fields: [createdById], references: [id])
  chaseTask   ChaseTask?           @relation(fields: [chaseTaskId], references: [id])

  @@index([transactionId, createdAt])
  @@index([chaseTaskId])
  @@index([agencyId, createdAt])
  @@index([channel, status, scheduledFor])
  @@index([purpose, createdAt])
  @@index([sentAt])
}

enum CommType {
  internal_note
  outbound
  inbound
}

enum CommMethod {
  email
  phone
  sms
  voicemail
  whatsapp
  post
}

enum OutboundChannel {
  email
  sms
  linkedin
  twitter
  in_app
  other
}

enum OutboundPurpose {
  chase
  password_reset
  retention_email
  scheduled_post
  digest
  notification
  other
}

enum OutboundStatus {
  draft
  scheduled
  queued
  sent
  delivered
  opened
  clicked
  bounced
  failed
  cancelled
}

model TransactionNote {
  id            String   @id @default(cuid())
  transactionId String
  content       String
  createdAt     DateTime @default(now())
  createdById   String?

  transaction PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdBy   User?               @relation(fields: [createdById], references: [id])

  @@index([transactionId, createdAt])
}

// ─── TransactionDocument ─────────────────────────────────────────────────────

model TransactionDocument {
  id            String   @id @default(cuid())
  transactionId String
  contactId     String?
  filename      String
  storagePath   String
  fileSize      Int
  mimeType      String
  source        String   @default("portal")
  createdAt     DateTime @default(now())

  transaction PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  contact     Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([transactionId, createdAt])
}

// ─── ManualTask ───────────────────────────────────────────────────────────────

model ManualTask {
  id             String           @id @default(cuid())
  agencyId       String
  transactionId  String?
  title            String
  notes            String?
  progressorNote   String?
  progressorNoteAt DateTime?
  status           ManualTaskStatus @default(open)
  assignedToId   String?
  dueDate        DateTime?
  isAgentRequest Boolean          @default(false)
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  agency      Agency               @relation(fields: [agencyId], references: [id])
  transaction PropertyTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  assignedTo  User?                @relation("ManualTaskAssignee", fields: [assignedToId], references: [id])
  createdBy   User                 @relation("ManualTaskCreator", fields: [createdById], references: [id])

  @@index([agencyId, status])
  @@index([transactionId])
}

enum ManualTaskStatus {
  open
  done
}

// ─── Chain ───────────────────────────────────────────────────────────────────

model PropertyChain {
  id        String   @id @default(cuid())
  agencyId  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Agency      @relation(fields: [agencyId], references: [id])
  links  ChainLink[]
}

model ChainLink {
  id              String   @id @default(cuid())
  chainId         String
  position        Int
  transactionId   String?
  externalAddress String?
  externalStatus  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chain       PropertyChain        @relation(fields: [chainId], references: [id], onDelete: Cascade)
  transaction PropertyTransaction? @relation(fields: [transactionId], references: [id])

  @@index([chainId, position])
}

// ─── Verified Sending Addresses ───────────────────────────────────────────────

model VerifiedDomain {
  id               String       @id @default(cuid())
  agencyId         String
  domain           String
  sendgridDomainId Int
  status           DomainStatus @default(pending)
  dkimValid        Boolean      @default(false)
  spfValid         Boolean      @default(false)
  cnameRecords     Json
  lastCheckedAt    DateTime?
  verifiedAt       DateTime?
  createdByUserId  String
  createdAt        DateTime     @default(now())

  agency       Agency              @relation(fields: [agencyId], references: [id])
  createdBy    User                @relation("DomainCreatedBy", fields: [createdByUserId], references: [id])
  userEmails   UserVerifiedEmail[]

  @@unique([agencyId, domain])
  @@index([agencyId, domain])
}

enum DomainStatus {
  pending
  verified
  failed
  removed
}

model UserVerifiedEmail {
  id                    String                  @id @default(cuid())
  userId                String
  email                 String
  verifiedDomainId      String?
  status                EmailVerificationStatus @default(pending_inbox_check)
  verificationCodeHash  String?
  verificationToken     String?
  verificationExpiresAt DateTime?
  verifiedAt            DateTime?
  lastUsedAt            DateTime?
  createdAt             DateTime                @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedDomain VerifiedDomain? @relation(fields: [verifiedDomainId], references: [id])

  @@unique([userId, email])
  @@index([userId, status])
}

enum EmailVerificationStatus {
  pending_inbox_check
  verified
  legacy_single_sender
  expired
  revoked
}

// ─── TransactionFlag ─────────────────────────────────────────────────────────

model TransactionFlag {
  id            String    @id @default(cuid())
  transactionId String
  agencyId      String
  kind          String
  reason        String
  resolvedAt    DateTime?
  detectedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transaction PropertyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, kind])
  @@index([agencyId, resolvedAt])
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

// NOTE: Account and Session are part of NextAuth's standard adapter scaffolding.
// We use the Credentials provider with JWT strategy, which does NOT write to
// either table. Both are expected to remain empty in production.
// Do not delete — keeping the schema standard simplifies any future migration
// to a database session strategy or addition of OAuth providers.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── FeedbackSubmission ───────────────────────────────────────────────────────

model FeedbackSubmission {
  id                 String    @id @default(cuid())
  category           String
  userId             String?
  userRole           String?
  userEmail          String?
  agencyId           String?
  field1             String?
  field2             String?
  url                String?
  browser            String?
  viewportSize       String?
  userAgent          String?
  screenshotUrl      String?
  screenshotFilename String?
  status             String    @default("new")
  emailSent          Boolean   @default(false)
  emailSentAt        DateTime?
  createdAt          DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])

  @@index([status])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ─── RetentionEmailLog ────────────────────────────────────────────────────────
// TODO: surface in admin dashboard — see future-admin-page ticket

model RetentionEmailLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailKey  String
  sentAt    DateTime @default(now())
  agencyId  String

  @@index([userId, emailKey])
  @@index([agencyId, sentAt])
  @@index([emailKey, sentAt])
}

// ─── Command Centre: Event ────────────────────────────────────────────────────
// Unified activity log. Append-only. Written via lib/command/events/write.ts.
// Instrumentation calls added per-service in separate PRs (never in this migration).

enum EventType {
  // Auth
  user_logged_in
  user_logged_out
  user_invited
  user_accepted_invite
  password_reset_requested
  password_reset_completed

  // Agency lifecycle
  agency_created
  agency_mode_changed
  agency_archived

  // Transaction lifecycle
  transaction_created
  transaction_archived
  transaction_status_changed

  // Milestone activity
  milestone_confirmed
  milestone_marked_not_required
  milestone_reversed
  exchange_gate_unlocked
  contracts_exchanged
  sale_completed

  // Communications
  chase_sent
  chase_message_generated
  email_parse_attempted

  // Files
  file_uploaded
  file_deleted

  // Feedback
  feedback_submitted

  // Admin
  admin_logged_in
  admin_action_performed
}

model Event {
  id             String    @id @default(cuid())
  occurredAt     DateTime  @default(now())
  agencyId       String?
  userId         String?
  isInternalUser Boolean   @default(false)
  type           EventType
  entityType     String?
  entityId       String?
  metadata       Json?

  @@index([occurredAt])
  @@index([agencyId, occurredAt])
  @@index([type, occurredAt])
  @@index([userId, occurredAt])
}

// ─── Command Centre: Rollup tables ───────────────────────────────────────────
// Pre-computed analytics rows. Written nightly by /api/cron/rollup-metrics.
// Idempotent writes keyed on the @@unique constraints below.

model DailyMetric {
  id          String            @id @default(cuid())
  date        DateTime          @db.Date

  // Scope keys — exactly one pattern is set per row
  agencyId    String?
  serviceType ServiceType?
  modeProfile AgencyModeProfile?

  // Transaction-derived counts (split by serviceType)
  transactionsCreated   Int @default(0)
  transactionsExchanged Int @default(0)
  transactionsCompleted Int @default(0)
  milestonesConfirmed   Int @default(0)
  chasesSent            Int @default(0)
  aiDraftsGenerated     Int @default(0)
  filesUploaded         Int @default(0)

  // Agency/user-derived counts
  signups             Int @default(0)
  logins              Int @default(0)
  uniqueActiveUsers   Int @default(0)
  feedbackSubmitted   Int @default(0)

  // AI spend (USD cents)
  aiSpendCents        Int @default(0)

  computedAt  DateTime @default(now())

  @@unique([date, agencyId, serviceType, modeProfile])
  @@index([date])
  @@index([agencyId, date])
  @@index([serviceType, date])
  @@index([modeProfile, date])
}

model WeeklyCohort {
  id           String            @id @default(cuid())
  signupWeek   DateTime          @db.Date
  modeProfile  AgencyModeProfile

  cohortSize   Int
  activeWeek1  Int @default(0)
  activeWeek2  Int @default(0)
  activeWeek4  Int @default(0)
  activeWeek8  Int @default(0)
  activeWeek12 Int @default(0)

  computedAt   DateTime @default(now())

  @@unique([signupWeek, modeProfile])
  @@index([signupWeek])
}

model JobRun {
  id          String    @id @default(cuid())
  jobName     String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  success     Boolean?
  rowsWritten Int?
  errorMessage String?

  @@index([jobName, startedAt])
}

// ─── Command Centre: Signal detection ────────────────────────────────────────
// Written by signal detectors in lib/command/insights/signals/.
// Append-only in practice; acknowledged flag is the only mutable field.

enum SignalSeverity {
  info
  opportunity
  leak
  critical
}

model Signal {
  id             String        @id @default(cuid())
  detectedAt     DateTime      @default(now())
  detectorName   String
  payload        Json
  confidence     Float
  severity       SignalSeverity
  acknowledged   Boolean       @default(false)
  acknowledgedAt DateTime?
  windowStart    DateTime
  windowEnd      DateTime

  @@index([detectedAt])
  @@index([severity, detectedAt])
  @@index([acknowledged, detectedAt])
}

// ─── Command Centre: Experiment Lab ──────────────────────────────────────────
// Lifecycle: proposed → active → concluded | abandoned.
// No UI in Phase 3 — mutated via /api/experiments/* routes only.

enum ExperimentStatus {
  proposed
  active
  concluded
  abandoned
}

enum ExperimentOutcome {
  win
  loss
  inconclusive
  mixed
}

model Experiment {
  id             String             @id @default(cuid())
  name           String
  hypothesis     String

  status         ExperimentStatus   @default(proposed)
  outcome        ExperimentOutcome?

  sourceSignalId String?
  sourceType     String?            // 'signal' | 'intuition' | 'customer_feedback' | 'other'

  primaryMetric    String
  guardrailMetrics String[]

  proposedAt   DateTime  @default(now())
  startedAt    DateTime?
  concludedAt  DateTime?

  // Frozen metric snapshots — set at start/conclude respectively
  baselineSnapshot   Json?
  resultSnapshot     Json?
  baselineWindowDays Int   @default(7)
  resultWindowDays   Int   @default(7)

  notes          String?
  conclusionNote String?

  createdByUserId String

  @@index([status, startedAt])
  @@index([sourceSignalId])
}

// ─── Command Centre: Deployment log ──────────────────────────────────────────
// Populated by POST /api/webhooks/vercel-deploy (HMAC-verified).
// Enables "what changed?" annotations on metric deltas (ADMIN_07 §6, ADMIN_08 §6).

model Deployment {
  id           String   @id @default(cuid())
  deployedAt   DateTime @default(now())
  version      String
  environment  String   // 'production' | 'staging'
  releaseNotes String?
  triggerType  String   // 'manual' | 'auto' | 'rollback'
  triggeredBy  String?

  @@index([deployedAt])
  @@index([environment, deployedAt])
}

// ─── Command Centre: Content drafter ─────────────────────────────────────────
// DraftPost — every generation session. Variant1/2 are the raw Claude outputs.
// editedText is the user's final version; chosenVariant records which was kept.
// VoiceSample — founder voice corpus used in generation prompts.

enum DraftChannel {
  linkedin
  twitter
  tiktok_script
  instagram_caption
  instagram_reel_script
}

model DraftPost {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())

  channel         DraftChannel
  tone            String?
  topicSeed       String
  sourceType      String       // "manual" | "activity-derived"

  prompt          String
  aiModel         String
  aiPromptVersion String

  variant1        String
  variant2        String
  editedText      String?
  chosenVariant   Int?         // 1 or 2 — which variant the user started from

  posted            Boolean @default(false)
  postedAt          DateTime?
  regenerationCount Int     @default(0)

  aiTokensInput   Int?
  aiTokensOutput  Int?

  topicId         String?      // ContentTopic this draft was generated from
  batchId         String?      // ContentBatch.id — set when batch email is sent

  approvedForBatch Boolean @default(false) // user flagged this variant for the morning batch

  @@index([createdAt])
  @@index([channel, createdAt])
  @@index([posted])
  @@index([topicId])
  @@index([approvedForBatch])
}

// ─── Command Centre: Content batch ───────────────────────────────────────────
// One record per calendar day an email digest is dispatched.

model ContentBatch {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  date      String    // "2026-05-03"
  status    String    @default("pending") // "pending" | "sent"
  sentAt    DateTime?
  itemCount Int       @default(0)

  @@unique([date])
  @@index([date])
}

// ─── Command Centre: Content engagement ──────────────────────────────────────
// Manually logged ~14 days after posting. One record per DraftPost.
// Used to score topic performance and feed back into the topic queue.

model ContentEngagement {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  draftPostId String   @unique
  channel     String
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  impressions Int?
  clicks      Int?
  notes       String?

  @@index([draftPostId])
  @@index([createdAt])
}

model VoiceSample {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  sampleType  String        // "manual_paste" | "qa_response" | "draft_edit_diff"
  questionKey String?       // e.g. "q1_near_miss" — set for sampleType = qa_response
  channel     DraftChannel?
  content     String
  notes       String?

  @@index([sampleType, createdAt])
  @@index([channel, createdAt])
}

// ─── Command Centre: Content topic queue ─────────────────────────────────────

model ContentTopic {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  text        String
  source      String        // "manual" | "activity_derived"
  channelHint DraftChannel?
  priority    Int           @default(0)  // higher = shown first
  status      String        @default("pending") // "pending" | "used" | "skipped"
  usedAt      DateTime?
  draftPostId String?

  @@index([status, priority, createdAt])
}

// ─── Command Centre: Generated images ────────────────────────────────────────

model GeneratedImage {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  imageType   String   // "text_card" | "chart" | "ai_generated"
  variant     String?  // "dark" | "light" for text/chart cards
  prompt      String?  // for ai_generated
  url         String   // Replicate URL for AI; parametric route URL for OG
  width       Int      @default(1200)
  height      Int      @default(628)
  aiModel     String?
  aiCostCents Int      @default(0)
  draftPostId String?

  @@index([createdAt])
  @@index([imageType, createdAt])
}

// ─── Command Centre: Admin audit log ─────────────────────────────────────────
// Append-only. No UPDATE/DELETE ever. Written via lib/command/audit/write.ts.

model AdminAuditLog {
  id          String   @id @default(cuid())
  occurredAt  DateTime @default(now())

  adminUserId String
  ipAddress   String?
  userAgent   String?

  action      String
  targetType  String?
  targetId    String?

  beforeValue Json?
  afterValue  Json?
  reason      String?

  @@index([occurredAt])
  @@index([adminUserId, occurredAt])
  @@index([action, occurredAt])
  @@index([targetType, targetId])
}
